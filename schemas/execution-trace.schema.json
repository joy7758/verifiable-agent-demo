{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/verifiable-agent-demo/schemas/execution-trace.schema.json",
  "title": "ExecutionTrace",
  "description": "Early-stage minimal execution trace schema supporting the current reference implementation.",
  "type": "object",
  "required": ["status", "trace"],
  "properties": {
    "status": {
      "type": "string",
      "description": "Outcome status for the bounded agent run."
    },
    "trace": {
      "type": "array",
      "description": "Ordered list of human-readable trace steps.",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "metadata": {
      "type": "object",
      "description": "Optional lightweight metadata attached to the trace.",
      "additionalProperties": true
    },
    "events": {
      "type": "array",
      "description": "Optional richer event objects for implementations that need more than a string trace.",
      "items": {
        "type": "object",
        "required": ["message"],
        "properties": {
          "message": {
            "type": "string"
          },
          "detail": {
            "type": "string"
          },
          "timestamp": {
            "type": "number"
          },
          "data": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
